{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium",
        "credentialsSource": "local"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium",
        "credentialsSource": "local"
      }
    },
    "testflight": {
      "distribution": "store",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "production": {
      "ios": {
        "resourceClass": "m-medium",
        "credentialsSource": "local"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "appleId": "flintrus@gmail.com",
        "ascAppId": "6785974487"
      }
    },
    "production": {
      "ios": {
        "appleId": "getsolomoney@gmail.com"
      }
    }
  }
