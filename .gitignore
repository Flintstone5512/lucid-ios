# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Signing certificates and provisioning profiles
# certs/ dir is NOT ignored — extension profiles are committed (no private keys)
certs/dist.p12
certs/ScrollTax.mobileprovision
credentials.json

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
# Allow extension provisioning profiles (no private keys, needed for EAS build)
!certs/Lucid_Shield_Action_AppStore.mobileprovision
!certs/Lucid_Shield_Configuration_AppStore.mobileprovision
!certs/Lucid_Shield_UI_AppStore.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
